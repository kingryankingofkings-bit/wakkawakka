# ==============================================================================
# WakkaWakka — Environment Variables
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WakkaWakka
NODE_ENV=development

# ------------------------------------------------------------------------------
# Database (Prisma / SQLite for development)
# For production, swap to a PostgreSQL / MySQL connection string.
# ------------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# Example PostgreSQL (production):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wakkawakka?schema=public&sslmode=require"

# ------------------------------------------------------------------------------
# Authentication — JWT secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long_replace_me
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_64_characters_long_replace_me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ------------------------------------------------------------------------------
# Firebase (client-side config — safe to expose via NEXT_PUBLIC_*)
# Create a project at https://console.firebase.google.com/
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (server-side ONLY — never expose with NEXT_PUBLIC_)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# The private key — keep newlines as \n literal or use base64 encoding
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Alternative: base64-encoded version of the entire service account JSON
FIREBASE_ADMIN_PRIVATE_KEY_BASE64=your_base64_encoded_service_account_json

# ------------------------------------------------------------------------------
# Email (Nodemailer)
# SMTP settings for transactional email (verification, password reset, etc.)
# ------------------------------------------------------------------------------
EMAIL_SERVER_HOST=smtp.mailtrap.io
EMAIL_SERVER_PORT=587
EMAIL_SERVER_SECURE=false
EMAIL_SERVER_USER=your_smtp_username
EMAIL_SERVER_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@wakkawakka.app
EMAIL_FROM_NAME=WakkaWakka

# SendGrid alternative:
# EMAIL_SERVER_HOST=smtp.sendgrid.net
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=apikey
# EMAIL_SERVER_PASSWORD=your_sendgrid_api_key

# ------------------------------------------------------------------------------
# Socket.io / Real-time
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
SOCKET_PORT=3001
SOCKET_CORS_ORIGIN=http://localhost:3000

# ------------------------------------------------------------------------------
# File Uploads / Storage
# Local disk (dev) — set UPLOAD_PROVIDER=local
# Firebase Storage (prod) — set UPLOAD_PROVIDER=firebase
# Cloudinary (prod) — set UPLOAD_PROVIDER=cloudinary
# ------------------------------------------------------------------------------
UPLOAD_PROVIDER=local
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp,image/avif
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg,video/quicktime
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/ogg,audio/wav,audio/webm

# Cloudinary (when UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=wakkawakka_unsigned

# ------------------------------------------------------------------------------
# Redis (optional — for caching, rate limiting, sessions at scale)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=20

# ------------------------------------------------------------------------------
# Content Moderation (optional)
# ------------------------------------------------------------------------------
# Google Cloud Vision API for image moderation
GOOGLE_CLOUD_VISION_KEY=your_google_cloud_vision_api_key

# OpenAI for text moderation (optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODERATION_MODEL=omni-moderation-latest

# ------------------------------------------------------------------------------
# Payments (Stripe — for tips, subscriptions, marketplace)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SUBSCRIPTION_PRICE_ID_BASIC=price_your_basic_price_id
STRIPE_SUBSCRIPTION_PRICE_ID_PRO=price_your_pro_price_id
STRIPE_SUBSCRIPTION_PRICE_ID_PREMIUM=price_your_premium_price_id

# ------------------------------------------------------------------------------
# Push Notifications (optional — web push via VAPID)
# Generate with: npx web-push generate-vapid-keys
# ------------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@wakkawakka.app

# ------------------------------------------------------------------------------
# Analytics (optional)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# CSRF secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your_csrf_secret_32_chars_minimum
# Encryption key for sensitive fields (AES-256 needs 32 bytes → 64 hex chars)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_replace_me_now_please

# ------------------------------------------------------------------------------
# Live Streaming (optional — RTMP ingest)
# ------------------------------------------------------------------------------
RTMP_SERVER_URL=rtmp://localhost:1935/live
RTMP_SECRET=your_rtmp_stream_secret
HLS_OUTPUT_DIR=./public/hls

# ------------------------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------------------------
# App-level feature flags
NEXT_PUBLIC_ENABLE_LIVE_STREAMS=true
NEXT_PUBLIC_ENABLE_AUDIO_ROOMS=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_STORIES=true
NEXT_PUBLIC_ENABLE_REELS=true
NEXT_PUBLIC_ENABLE_SUBSCRIPTIONS=true
NEXT_PUBLIC_ENABLE_TIPS=true
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Default pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Story / ephemeral content TTL (hours)
STORY_TTL_HOURS=24
EPHEMERAL_POST_MAX_TTL_HOURS=168
