// =============================================================================
// WakkaWakka — Prisma Schema
// Provider : PostgreSQL
// Generator: @prisma/client
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// NOTE: SQLite does not support native enums. We model them as String and
//       validate at the application layer. When migrating to PostgreSQL,
//       convert these to proper Prisma enum declarations.
// =============================================================================
// PostType        : TEXT | IMAGE | VIDEO | REEL | STORY | AUDIO | LIVE
// PostVisibility  : PUBLIC | FOLLOWERS | PRIVATE
// FollowStatus    : PENDING | ACCEPTED
// LikeType        : LIKE | LOVE | HAHA | WOW | SAD | ANGRY
// NotificationType: LIKE | COMMENT | FOLLOW | MENTION | REPLY | SHARE |
//                   LIVE_START | STORY_VIEW | COMMUNITY_INVITE | BADGE |
//                   SUBSCRIPTION | TIP | PURCHASE | SYSTEM
// TargetType      : POST | COMMENT | STORY | COMMUNITY | LIVE_STREAM | USER
// OrderStatus     : PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED | REFUNDED
// ReportReason    : SPAM | HARASSMENT | HATE_SPEECH | NUDITY | VIOLENCE |
//                   COPYRIGHT | MISINFORMATION | OTHER
// ReportStatus    : PENDING | REVIEWED | RESOLVED | DISMISSED
// SubscriptionStatus: ACTIVE | PAST_DUE | CANCELLED | TRIALING | INCOMPLETE
// VerificationTier: NONE | BLUE | GOLD | PLATINUM
// Theme           : SYSTEM | LIGHT | DARK

// =============================================================================
// User
// =============================================================================
model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  email              String    @unique
  displayName        String
  bio                String?
  avatar             String?
  coverImage         String?
  website            String?
  location           String?
  birthdate          DateTime?
  isVerified         Boolean   @default(false)
  verificationTier   String    @default("NONE")
  isPremium          Boolean   @default(false)
  isPrivate          Boolean   @default(false)
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  theme              String    @default("SYSTEM")
  accentColor        String    @default("#3b82f6")
  language           String    @default("en")
  passwordHash       String?
  firebaseUid        String?   @unique
  isActive           Boolean   @default(true)
  isAdmin            Boolean   @default(false)
  isBanned           Boolean   @default(false)
  bannedAt           DateTime?
  bannedReason       String?
  lastSeenAt         DateTime?
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  posts              Post[]
  comments           Comment[]
  stories            Story[]
  communityPosts     CommunityPost[]
  followers          Follow[]         @relation("FollowTarget")
  following          Follow[]         @relation("FollowSource")
  blocksGiven        Block[]          @relation("BlockSource")
  blocksReceived     Block[]          @relation("BlockTarget")
  sentMessages       Message[]
  conversations      ConversationMember[]
  likes              Like[]
  notifications      Notification[]   @relation("NotificationRecipient")
  notificationActor  Notification[]   @relation("NotificationActor")
  createdCommunities Community[]      @relation("CommunityCreator")
  communityMembers   CommunityMember[]
  liveStreams        LiveStream[]     @relation("LiveStreamHost")
  coHostedStreams    LiveStreamCoHost[]
  audioRoomsHosted   AudioRoom[]      @relation("AudioRoomHost")
  audioRoomSpeakers  AudioRoomSpeaker[]
  audioRoomListeners AudioRoomListener[]
  products           Product[]
  buyerOrders        Order[]          @relation("OrderBuyer")
  badges             Badge[]
  streak             Streak?
  subscriptionsGiven Subscription[]   @relation("SubscriptionSubscriber")
  subscriptionsReceived Subscription[] @relation("SubscriptionCreator")
  tipsGiven          Tip[]            @relation("TipSender")
  tipsReceived       Tip[]            @relation("TipReceiver")
  reportsGiven       Report[]         @relation("ReportSource")
  analytics          Analytics[]
  savedHashtags      UserSavedHashtag[]
  bookmarks          Bookmark[]
  viewedStories      StoryView[]

  // Relations — friends (social graph)
  friendRequestsSent     FriendRequest[] @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestReceiver")
  friendshipsA           Friendship[]    @relation("FriendshipUserA")
  friendshipsB           Friendship[]    @relation("FriendshipUserB")
  closeFriendsAdded      CloseFriend[]   @relation("CloseFriendOwner")
  closeFriendOf          CloseFriend[]   @relation("CloseFriendTarget")

  // Relations — polls
  pollsCreated           Poll[]
  pollVotes              PollVote[]

  // Relations — albums & photos
  albums                 Album[]
  photos                 Photo[]

  // Relations — events
  eventsCreated          Event[]         @relation("EventCreator")
  eventRsvps             EventAttendee[]

  // Relations — pages
  pagesOwned             Page[]          @relation("PageOwner")
  pageMemberships        PageMember[]
  pageFollows            PageFollower[]

  // Relations — community join requests
  communityJoinRequests  CommunityJoinRequest[]

  // Relations — tagging & timeline
  taggedInPosts          PostTag[]       @relation("PostTagUser")
  lifeEvents             LifeEvent[]

  @@index([username])
  @@index([email])
  @@index([firebaseUid])
  @@index([createdAt])
}

// =============================================================================
// Post
// =============================================================================
model Post {
  id              String    @id @default(cuid())
  content         String?
  authorId        String
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type            String    @default("TEXT")
  visibility      String    @default("PUBLIC")
  mediaUrls       String    @default("[]")
  hashtags        String    @default("[]")
  collaboratorIds String    @default("[]")
  productTag      String?
  isEphemeral     Boolean   @default(false)
  expiresAt       DateTime?
  likesCount      Int       @default(0)
  commentsCount   Int       @default(0)
  sharesCount     Int       @default(0)
  viewsCount      Int       @default(0)
  isPinned        Boolean   @default(false)
  isArchived      Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  editedAt        DateTime?
  originalPostId  String?
  originalPost    Post?     @relation("PostShares", fields: [originalPostId], references: [id])
  shares          Post[]    @relation("PostShares")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  comments        Comment[]
  likes           Like[]
  reports         Report[]  @relation("ReportedPost")
  bookmarks       Bookmark[]
  postHashtags    PostHashtag[]
  poll            Poll?
  tags            PostTag[]

  @@index([authorId])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@index([isEphemeral, expiresAt])
  @@index([isDeleted])
}

// =============================================================================
// Comment
// =============================================================================
model Comment {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")
  content     String
  mediaUrl    String?
  likesCount  Int       @default(0)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  editedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  likes       Like[]
  reports     Report[]  @relation("ReportedComment")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
}

// =============================================================================
// Like
// =============================================================================
model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  type      String   @default("LIKE")
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@index([userId])
}

// =============================================================================
// Follow
// =============================================================================
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)
  status      String   @default("ACCEPTED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([status])
}

// =============================================================================
// Block
// =============================================================================
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlockSource", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// =============================================================================
// Conversation
// =============================================================================
model Conversation {
  id            String   @id @default(cuid())
  name          String?
  isGroup       Boolean  @default(false)
  avatarUrl     String?
  description   String?
  createdById   String?
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members     ConversationMember[]
  messages    Message[]

  @@index([createdAt])
  @@index([lastMessageAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin        Boolean      @default(false)
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?
  isMuted        Boolean      @default(false)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

// =============================================================================
// Message
// =============================================================================
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String?
  mediaUrl       String?
  type           String       @default("TEXT")
  isRead         Boolean      @default(false)
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  editedAt       DateTime?
  replyToId      String?
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReplies")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reactions      MessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isDeleted])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// =============================================================================
// Notification
// =============================================================================
model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type       String
  actorId    String?
  actor      User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetId   String?
  targetType String?
  message    String?
  imageUrl   String?
  actionUrl  String?
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([actorId])
}

// =============================================================================
// Story
// =============================================================================
model Story {
  id        String      @id @default(cuid())
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mediaUrl  String
  type      String      @default("IMAGE")
  caption   String?
  linkUrl   String?
  musicUrl  String?
  filter    String?
  duration  Int?
  expiresAt DateTime
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  views     StoryView[]

  @@index([authorId])
  @@index([expiresAt])
  @@index([isActive])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId  String
  viewer    User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([storyId, viewerId])
  @@index([storyId])
  @@index([viewerId])
}

// =============================================================================
// Community
// =============================================================================
model Community {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  avatarUrl   String?
  coverImage  String?
  creatorId   String
  creator     User     @relation("CommunityCreator", fields: [creatorId], references: [id])
  category    String   @default("GENERAL")
  visibility  String   @default("PUBLIC")
  rules       String?
  tags        String   @default("[]")
  isVerified  Boolean  @default(false)
  memberCount Int      @default(0)
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members      CommunityMember[]
  posts        CommunityPost[]
  reports      Report[]  @relation("ReportedCommunity")
  joinRequests CommunityJoinRequest[]

  @@index([creatorId])
  @@index([category])
  @@index([visibility])
  @@index([createdAt])
}

model CommunityMember {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("MEMBER")
  joinedAt    DateTime  @default(now())
  isBanned    Boolean   @default(false)
  isMuted     Boolean   @default(false)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@index([role])
}

// =============================================================================
// CommunityPost
// =============================================================================
model CommunityPost {
  id            String    @id @default(cuid())
  communityId   String
  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content       String
  mediaUrls     String    @default("[]")
  hashtags      String    @default("[]")
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  isPinned      Boolean   @default(false)
  isApproved    Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  likes         CommunityPostLike[]
  comments      CommunityPostComment[]

  @@index([communityId])
  @@index([authorId])
  @@index([createdAt])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model CommunityPostComment {
  id         String        @id @default(cuid())
  postId     String
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String
  content    String
  parentId   String?
  parent     CommunityPostComment?  @relation("CommunityCommentReplies", fields: [parentId], references: [id])
  replies    CommunityPostComment[] @relation("CommunityCommentReplies")
  likesCount Int           @default(0)
  isDeleted  Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

// =============================================================================
// LiveStream
// =============================================================================
model LiveStream {
  id           String   @id @default(cuid())
  hostId       String
  host         User     @relation("LiveStreamHost", fields: [hostId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  thumbnailUrl String?
  streamKey    String   @unique @default(cuid())
  playbackUrl  String?
  chatEnabled  Boolean  @default(true)
  viewerCount  Int      @default(0)
  peakViewers  Int      @default(0)
  isActive     Boolean  @default(false)
  isRecorded   Boolean  @default(false)
  recordingUrl String?
  giftTotal    Float    @default(0)
  tags         String   @default("[]")
  category     String?
  visibility   String   @default("PUBLIC")
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coHosts      LiveStreamCoHost[]
  gifts        LiveStreamGift[]

  @@index([hostId])
  @@index([isActive])
  @@index([createdAt])
}

model LiveStreamCoHost {
  id           String     @id @default(cuid())
  liveStreamId String
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt     DateTime   @default(now())

  @@unique([liveStreamId, userId])
  @@index([liveStreamId])
}

model LiveStreamGift {
  id           String     @id @default(cuid())
  liveStreamId String
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  senderId     String
  giftType     String
  giftName     String
  amount       Float
  quantity     Int        @default(1)
  sentAt       DateTime   @default(now())

  @@index([liveStreamId])
  @@index([senderId])
}

// =============================================================================
// AudioRoom
// =============================================================================
model AudioRoom {
  id           String   @id @default(cuid())
  hostId       String
  host         User     @relation("AudioRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  isActive     Boolean  @default(false)
  isRecorded   Boolean  @default(false)
  recordingUrl String?
  maxSpeakers  Int      @default(10)
  tags         String   @default("[]")
  category     String?
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  speakers    AudioRoomSpeaker[]
  listeners   AudioRoomListener[]

  @@index([hostId])
  @@index([isActive])
  @@index([createdAt])
}

model AudioRoomSpeaker {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isMuted     Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@unique([audioRoomId, userId])
  @@index([audioRoomId])
}

model AudioRoomListener {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@unique([audioRoomId, userId])
  @@index([audioRoomId])
}

// =============================================================================
// Product (Marketplace)
// =============================================================================
model Product {
  id           String   @id @default(cuid())
  sellerId     String
  seller       User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Float
  images       String   @default("[]")
  category     String
  tags         String   @default("[]")
  inStock      Boolean  @default(true)
  stockCount   Int?
  sku          String?
  condition    String   @default("NEW")
  shippingInfo String?
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  salesCount   Int      @default(0)
  viewsCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders      Order[]
  reviews     ProductReview[]

  @@index([sellerId])
  @@index([category])
  @@index([inStock])
  @@index([price])
  @@index([createdAt])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([productId, reviewerId])
  @@index([productId])
}

// =============================================================================
// Order
// =============================================================================
model Order {
  id              String   @id @default(cuid())
  buyerId         String
  buyer           User     @relation("OrderBuyer", fields: [buyerId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int      @default(1)
  unitPrice       Float
  total           Float
  status          String   @default("PENDING")
  shippingAddress String?
  trackingNumber  String?
  notes           String?
  stripePaymentId String?
  refundedAt      DateTime?
  refundReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([buyerId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Badge (Gamification)
// =============================================================================
model Badge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  name        String
  description String?
  iconUrl     String?
  tier        String   @default("BRONZE")
  awardedAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
}

// =============================================================================
// Streak (Gamification)
// =============================================================================
model Streak {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActivityAt  DateTime @default(now())
  totalDaysActive Int      @default(0)
  weeklyGoal      Int      @default(7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// =============================================================================
// Report (Moderation)
// =============================================================================
model Report {
  id          String    @id @default(cuid())
  reporterId  String
  reporter    User      @relation("ReportSource", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId    String
  targetType  String
  reason      String
  description String?
  status      String    @default("PENDING")
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  post        Post?      @relation("ReportedPost",      fields: [postId], references: [id])
  postId      String?
  comment     Comment?   @relation("ReportedComment",   fields: [commentId], references: [id])
  commentId   String?
  community   Community? @relation("ReportedCommunity", fields: [communityId], references: [id])
  communityId String?

  @@index([reporterId])
  @@index([targetId, targetType])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Hashtag
// =============================================================================
model Hashtag {
  id         String   @id @default(cuid())
  name       String   @unique
  postCount  Int      @default(0)
  isTrending Boolean  @default(false)
  trendScore Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  posts   PostHashtag[]
  savedBy UserSavedHashtag[]

  @@index([name])
  @@index([isTrending])
  @@index([trendScore])
}

model PostHashtag {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([postId, hashtagId])
  @@index([hashtagId])
}

model UserSavedHashtag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@unique([userId, hashtagId])
  @@index([userId])
}

// =============================================================================
// Subscription (Creator monetisation)
// =============================================================================
model Subscription {
  id                 String   @id @default(cuid())
  subscriberId       String
  subscriber         User     @relation("SubscriptionSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  creatorId          String
  creator            User     @relation("SubscriptionCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  tier               String   @default("BASIC")
  amount             Float
  currency           String   @default("USD")
  status             String   @default("ACTIVE")
  stripeSubId        String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([subscriberId, creatorId])
  @@index([subscriberId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Tip (Direct creator support)
// =============================================================================
model Tip {
  id              String   @id @default(cuid())
  senderId        String
  sender          User     @relation("TipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId      String
  receiver        User     @relation("TipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  amount          Float
  currency        String   @default("USD")
  message         String?
  stripePaymentId String?
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// =============================================================================
// Analytics (per-user daily aggregates)
// =============================================================================
model Analytics {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  impressions    Int      @default(0)
  reach          Int      @default(0)
  profileViews   Int      @default(0)
  followerGrowth Int      @default(0)
  postLikes      Int      @default(0)
  postComments   Int      @default(0)
  postShares     Int      @default(0)
  videoViews     Int      @default(0)
  liveViewers    Int      @default(0)
  revenueUsd     Float    @default(0)
  linkClicks     Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// =============================================================================
// Bookmark (Post saves)
// =============================================================================
model Bookmark {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId         String
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  collectionName String?  @default("All Bookmarks")
  createdAt      DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}
// =============================================================================
// Friends (social graph — distinct from follows)
// =============================================================================
model FriendRequest {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  /// FriendRequestStatus: PENDING | ACCEPTED | DECLINED
  status      String   @default("PENDING")
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Friendship {
  id        String   @id @default(cuid())
  // userAId < userBId enforced at app layer to keep pairs unique
  userAId   String
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model CloseFriend {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation("CloseFriendOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friendId  String
  friend    User     @relation("CloseFriendTarget", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ownerId, friendId])
  @@index([ownerId])
}

// =============================================================================
// Polls
// =============================================================================
model Poll {
  id            String       @id @default(cuid())
  postId        String       @unique
  post          Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  creatorId     String
  creator       User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  question      String
  allowMultiple Boolean      @default(false)
  expiresAt     DateTime?
  isClosed      Boolean      @default(false)
  createdAt     DateTime     @default(now())

  options       PollOption[]
  votes         PollVote[]

  @@index([creatorId])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  position  Int        @default(0)
  votesCount Int       @default(0)

  votes     PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([optionId, userId])
  @@index([pollId])
  @@index([userId])
}

// =============================================================================
// Photo Albums
// =============================================================================
model Album {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  coverUrl    String?
  /// AlbumVisibility: PUBLIC | FRIENDS | PRIVATE
  visibility  String   @default("PUBLIC")
  photoCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  photos      Photo[]

  @@index([ownerId])
}

model Photo {
  id          String   @id @default(cuid())
  albumId     String
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  url         String
  caption     String?
  width       Int?
  height      Int?
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([albumId])
  @@index([uploaderId])
}

// =============================================================================
// Events
// =============================================================================
model Event {
  id            String          @id @default(cuid())
  creatorId     String
  creator       User            @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  coverImage    String?
  location      String?
  isOnline      Boolean         @default(false)
  onlineUrl     String?
  /// EventVisibility: PUBLIC | FRIENDS | PRIVATE
  visibility    String          @default("PUBLIC")
  category      String?
  startsAt      DateTime
  endsAt        DateTime?
  goingCount    Int             @default(0)
  interestedCount Int           @default(0)
  isCancelled   Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  attendees     EventAttendee[]

  @@index([creatorId])
  @@index([startsAt])
  @@index([visibility])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// RsvpStatus: GOING | INTERESTED | DECLINED | INVITED
  status    String   @default("INTERESTED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// =============================================================================
// Pages (business / creator pages)
// =============================================================================
model Page {
  id           String         @id @default(cuid())
  ownerId      String
  owner        User           @relation("PageOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  slug         String         @unique
  category     String         @default("GENERAL")
  description  String?
  avatarUrl    String?
  coverImage   String?
  website      String?
  isVerified   Boolean        @default(false)
  followerCount Int           @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  roles        PageMember[]
  followers    PageFollower[]

  @@index([ownerId])
  @@index([category])
}

model PageMember {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// PageRole: ADMIN | EDITOR | MODERATOR | ANALYST
  role      String   @default("EDITOR")
  createdAt DateTime @default(now())

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}

model PageFollower {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}

// =============================================================================
// Community join requests (private group approvals)
// =============================================================================
model CommunityJoinRequest {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JoinRequestStatus: PENDING | APPROVED | REJECTED
  status      String    @default("PENDING")
  message     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@index([status])
}

// =============================================================================
// Post tags (tagging people in posts/photos)
// =============================================================================
model PostTag {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("PostTagUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// =============================================================================
// Life events (profile timeline milestones)
// =============================================================================
model LifeEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  category    String   @default("GENERAL")
  description String?
  icon        String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([occurredAt])
}
