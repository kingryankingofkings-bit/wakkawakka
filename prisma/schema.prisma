// =============================================================================
// WakkaWakka — Prisma Schema
// Provider : PostgreSQL
// Generator: @prisma/client
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// NOTE: Enum values are modeled as String fields and validated at the
//       application layer. This provides flexibility across providers.
// =============================================================================
// PostType        : TEXT | IMAGE | VIDEO | REEL | STORY | AUDIO | LIVE
// PostVisibility  : PUBLIC | FOLLOWERS | PRIVATE
// FollowStatus    : PENDING | ACCEPTED
// LikeType        : LIKE | LOVE | HAHA | WOW | SAD | ANGRY
// NotificationType: LIKE | COMMENT | FOLLOW | MENTION | REPLY | SHARE |
//                   LIVE_START | STORY_VIEW | COMMUNITY_INVITE | BADGE |
//                   SUBSCRIPTION | TIP | PURCHASE | SYSTEM
// TargetType      : POST | COMMENT | STORY | COMMUNITY | LIVE_STREAM | USER
// OrderStatus     : PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED | REFUNDED
// ReportReason    : SPAM | HARASSMENT | HATE_SPEECH | NUDITY | VIOLENCE |
//                   COPYRIGHT | MISINFORMATION | OTHER
// ReportStatus    : PENDING | REVIEWED | RESOLVED | DISMISSED
// SubscriptionStatus: ACTIVE | PAST_DUE | CANCELLED | TRIALING | INCOMPLETE
// VerificationTier: NONE | BLUE | GOLD | PLATINUM
// Theme           : SYSTEM | LIGHT | DARK

// =============================================================================
// Account (Master User)
// =============================================================================
model Account {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String?
  firebaseUid         String?   @unique
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  profiles Profile[]
}

// =============================================================================
// Profile
// =============================================================================
model Profile {
  id                       String    @id @default(cuid())
  username                 String
  type                     String    @default("PERSONAL") // STREAMING | SOCIALIZING | ANONYMOUS | LEARNING | PROFESSIONAL
  accountId                String
  account                  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  displayName              String
  bio                      String?
  avatar                   String?
  coverImage               String?
  website                  String?
  location                 String?
  birthdate                DateTime?
  isVerified               Boolean   @default(false)
  verificationTier         String    @default("NONE")
  isPremium                Boolean   @default(false)
  isPrivate                Boolean   @default(false)
  theme                    String    @default("SYSTEM")
  accentColor              String    @default("#3b82f6")
  language                 String    @default("en")
  isActive                 Boolean   @default(true)
  isAdmin                  Boolean   @default(false)
  isBanned                 Boolean   @default(false)
  bannedAt                 DateTime?
  bannedReason             String?
  lastSeenAt               DateTime?
  profileSoundtrack        String?
  profileSoundtrackVisible Boolean   @default(true)

  // Professional features
  professionalTier            String @default("NONE") // NONE | SIMPLE | BETTER | BEST | PURE
  idVerificationStatus        String @default("UNVERIFIED") // UNVERIFIED | PENDING | VERIFIED
  freeCoursesCreatedThisMonth Int    @default(0)
  paidCoursesCreatedThisMonth Int    @default(0)
  averageCourseRating         Float  @default(0.0)
  courseRating                Float?
  courseRatingCount           Int    @default(0)

  // Profile customization
  customCss         String?
  profileTabOrder   String? // JSON array of tab ids
  hideFollowerCount Boolean @default(false)
  pinnedPostId      String?
  streakDays        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts                 Post[]
  comments              Comment[]
  stories               Story[]
  communityPosts        CommunityPost[]
  followers             Follow[]                     @relation("FollowTarget")
  following             Follow[]                     @relation("FollowSource")
  blocksGiven           Block[]                      @relation("BlockSource")
  blocksReceived        Block[]                      @relation("BlockTarget")
  sentMessages          Message[]
  conversations         ConversationMember[]
  likes                 Like[]
  notifications         Notification[]               @relation("NotificationRecipient")
  notificationActor     Notification[]               @relation("NotificationActor")
  createdCommunities    Community[]                  @relation("CommunityCreator")
  communityMembers      CommunityMember[]
  liveStreams           LiveStream[]                 @relation("LiveStreamHost")
  coHostedStreams       LiveStreamCoHost[]
  audioRoomsHosted      AudioRoom[]                  @relation("AudioRoomHost")
  audioRoomSpeakers     AudioRoomSpeaker[]
  audioRoomListeners    AudioRoomListener[]
  podcasts              Podcast[]
  playlists             AudioPlaylist[]
  transcriptSegments    AudioRoomTranscriptSegment[]
  products              Product[]
  buyerOrders           Order[]                      @relation("OrderBuyer")
  badges                Badge[]
  streak                Streak?
  subscriptionsGiven    Subscription[]               @relation("SubscriptionSubscriber")
  subscriptionsReceived Subscription[]               @relation("SubscriptionCreator")
  tipsGiven             Tip[]                        @relation("TipSender")
  tipsReceived          Tip[]                        @relation("TipReceiver")
  reportsGiven          Report[]                     @relation("ReportSource")
  analytics             Analytics[]
  savedHashtags         UserSavedHashtag[]
  bookmarks             Bookmark[]
  viewedStories         StoryView[]
  searchHistories       SearchHistory[]
  cart                  Cart?
  ads                   Ad[]
  webhookSubscriptions  WebhookSubscription[]
  datingProfile         DatingProfile?
  fundraisers           Fundraiser[]
  bounties              Bounty[]
  fundraiserDonations   FundraiserDonation[]

  // Relations for Server/Channel Architecture (Batch 7)
  ownedServers      Server[]          @relation("ServerOwner")
  serverMemberships ServerMember[]
  serverBoosts      ServerBoost[]
  soundboardSounds  SoundboardSound[]
  customEmojis      CustomEmoji[]
  serverMessages    ServerMessage[]

  // Relations — friends (social graph)
  friendRequestsSent     FriendRequest[] @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestReceiver")
  friendshipsA           Friendship[]    @relation("FriendshipUserA")
  friendshipsB           Friendship[]    @relation("FriendshipUserB")
  closeFriendsAdded      CloseFriend[]   @relation("CloseFriendOwner")
  closeFriendOf          CloseFriend[]   @relation("CloseFriendTarget")

  // Relations — polls
  pollsCreated Poll[]
  pollVotes    PollVote[]

  // Relations — albums & photos
  albums Album[]
  photos Photo[]

  // Relations — events
  eventsCreated Event[]         @relation("EventCreator")
  eventRsvps    EventAttendee[]

  // Relations — pages
  pagesOwned      Page[]         @relation("PageOwner")
  pageMemberships PageMember[]
  pageFollows     PageFollower[]

  // Relations — community join requests
  communityJoinRequests CommunityJoinRequest[]

  // Relations — tagging & timeline
  taggedInPosts  PostTag[]               @relation("PostTagUser")
  lifeEvents     LifeEvent[]
  channelPoints  Int                     @default(0)
  predictionBets PredictionBet[]
  clipsCreated   Clip[]                  @relation("ClipCreator")
  chatMessages   LiveStreamChatMessage[] @relation("UserChatMessages")

  headline    String?
  workHistory String  @default("[]") // JSON string array
  education   String  @default("[]") // JSON string array
  skills      String  @default("[]") // JSON string array
  inmailQuota Int     @default(0)

  ownedCompanies           Company[]            @relation("CompanyOwner")
  companyMemberships       CompanyMember[]
  companyFollows           CompanyFollower[]
  postedJobs               Job[]                @relation("JobPoster")
  jobApplications          JobApplication[]     @relation("JobApplicant")
  sentInMails              InMailMessage[]      @relation("InMailSender")
  receivedInMails          InMailMessage[]      @relation("InMailReceiver")
  receivedEndorsements     Endorsement[]        @relation("EndorsementTarget")
  givenEndorsements        Endorsement[]        @relation("EndorsementSender")
  requestedRecommendations Recommendation[]     @relation("RecommendationRequester")
  receivedRecommendations  Recommendation[]     @relation("RecommendationReceiver")
  writtenRecommendations   Recommendation[]     @relation("RecommendationWriter")
  learningEnrollments      LearningEnrollment[]
  articles                 Article[]            @relation("ArticleAuthor")

  // Relations for Forum-style Forum & Voting (Batch 9)
  forumKarma          Int               @default(0)
  createdSubforums    Subforum[]        @relation("SubforumCreator")
  subforumMemberships SubforumMember[]
  subforumPosts       SubforumPost[]
  subforumComments    SubforumComment[]
  forumVotes          ForumVote[]
  sentAwards          ForumAward[]      @relation("AwardsSent")
  receivedAwards      ForumAward[]      @relation("AwardsReceived")
  modActions          ForumModAction[]  @relation("ModActionModerator")
  targetModActions    ForumModAction[]  @relation("ModActionTargetUser")

  // Relations for Camera & AR (Batch 10)
  locationMap               UserLocation?
  disappearingMediaSent     DisappearingMedia[] @relation("DisappearingMediaSent")
  disappearingMediaReceived DisappearingMedia[] @relation("DisappearingMediaReceived")
  savedMemories             SavedMemory[]

  @@index([username])
  @@index([accountId])
  @@index([createdAt])
}

// =============================================================================
// Post
// =============================================================================
model Post {
  id              String    @id @default(cuid())
  content         String?
  authorId        String
  author          Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type            String    @default("TEXT")
  visibility      String    @default("PUBLIC")
  mediaUrls       String    @default("[]")
  hashtags        String    @default("[]")
  collaboratorIds String    @default("[]")
  productTag      String?
  isEphemeral     Boolean   @default(false)
  expiresAt       DateTime?
  scheduledAt     DateTime?
  btsUrl          String?
  greenScreenBg   String?
  labels          String?   @default("[]")
  isExplicit      Boolean   @default(false)

  likesCount     Int       @default(0)
  commentsCount  Int       @default(0)
  sharesCount    Int       @default(0)
  viewsCount     Int       @default(0)
  isPinned       Boolean   @default(false)
  isArchived     Boolean   @default(false)
  isDeleted      Boolean   @default(false)
  isFlagged      Boolean   @default(false)
  deletedAt      DateTime?
  editedAt       DateTime?
  originalPostId String?
  originalPost   Post?     @relation("PostShares", fields: [originalPostId], references: [id])
  shares         Post[]    @relation("PostShares")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  comments     Comment[]
  likes        Like[]
  reports      Report[]      @relation("ReportedPost")
  bookmarks    Bookmark[]
  postHashtags PostHashtag[]
  poll         Poll?
  tags         PostTag[]

  @@index([authorId])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@index([isFlagged])
  @@index([isEphemeral, expiresAt])
  @@index([isDeleted])
}

// =============================================================================
// Comment
// =============================================================================
model Comment {
  id         String    @id @default(cuid())
  postId     String
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String
  author     Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[] @relation("CommentReplies")
  content    String
  mediaUrl   String?
  likesCount Int       @default(0)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  editedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  likes   Like[]
  reports Report[] @relation("ReportedComment")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
}

// =============================================================================
// Like
// =============================================================================
model Like {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  type      String   @default("LIKE")
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@index([userId])
}

// =============================================================================
// Follow
// =============================================================================
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    Profile  @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   Profile  @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)
  status      String   @default("ACCEPTED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([status])
}

// =============================================================================
// Block
// =============================================================================
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   Profile  @relation("BlockSource", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   Profile  @relation("BlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// =============================================================================
// Conversation
// =============================================================================
model Conversation {
  id            String    @id @default(cuid())
  name          String?
  isGroup       Boolean   @default(false)
  avatarUrl     String?
  description   String?
  createdById   String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([createdAt])
  @@index([lastMessageAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin        Boolean      @default(false)
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?
  isMuted        Boolean      @default(false)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

// =============================================================================
// Message
// =============================================================================
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         Profile      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String?
  mediaUrl       String?
  type           String       @default("TEXT")
  isRead         Boolean      @default(false)
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  editedAt       DateTime?
  replyToId      String?
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReplies")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reactions MessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isDeleted])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// =============================================================================
// Notification
// =============================================================================
model Notification {
  id         String    @id @default(cuid())
  userId     String
  user       Profile   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type       String
  actorId    String?
  actor      Profile?  @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetId   String?
  targetType String?
  message    String?
  imageUrl   String?
  actionUrl  String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([actorId])
}

// =============================================================================
// Story
// =============================================================================
model Story {
  id        String   @id @default(cuid())
  authorId  String
  author    Profile  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mediaUrl  String
  type      String   @default("IMAGE")
  caption   String?
  linkUrl   String?
  musicUrl  String?
  filter    String?
  duration  Int?
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  views StoryView[]

  @@index([authorId])
  @@index([expiresAt])
  @@index([isActive])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId String
  viewer   Profile  @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([storyId, viewerId])
  @@index([storyId])
  @@index([viewerId])
}

// =============================================================================
// Community
// =============================================================================
model Community {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  avatarUrl   String?
  coverImage  String?
  creatorId   String
  creator     Profile  @relation("CommunityCreator", fields: [creatorId], references: [id])
  category    String   @default("GENERAL")
  visibility  String   @default("PUBLIC")
  rules       String?
  tags        String   @default("[]")
  isVerified  Boolean  @default(false)
  memberCount Int      @default(0)
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members      CommunityMember[]
  posts        CommunityPost[]
  reports      Report[]               @relation("ReportedCommunity")
  joinRequests CommunityJoinRequest[]
  events       Event[]

  @@index([creatorId])
  @@index([category])
  @@index([visibility])
  @@index([createdAt])
}

model CommunityMember {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("MEMBER")
  flair       String?
  joinedAt    DateTime  @default(now())
  isBanned    Boolean   @default(false)
  isMuted     Boolean   @default(false)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@index([role])
}

// =============================================================================
// CommunityPost
// =============================================================================
model CommunityPost {
  id            String    @id @default(cuid())
  communityId   String
  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  authorId      String
  author        Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content       String
  mediaUrls     String    @default("[]")
  hashtags      String    @default("[]")
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  isPinned      Boolean   @default(false)
  isApproved    Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  flair         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  likes    CommunityPostLike[]
  comments CommunityPostComment[]

  @@index([communityId])
  @@index([authorId])
  @@index([createdAt])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model CommunityPostComment {
  id         String                 @id @default(cuid())
  postId     String
  post       CommunityPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String
  content    String
  parentId   String?
  parent     CommunityPostComment?  @relation("CommunityCommentReplies", fields: [parentId], references: [id])
  replies    CommunityPostComment[] @relation("CommunityCommentReplies")
  likesCount Int                    @default(0)
  isDeleted  Boolean                @default(false)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

// =============================================================================
// LiveStream
// =============================================================================
model LiveStream {
  id           String    @id @default(cuid())
  hostId       String
  host         Profile   @relation("LiveStreamHost", fields: [hostId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  thumbnailUrl String?
  streamKey    String    @unique @default(cuid())
  playbackUrl  String?
  chatEnabled  Boolean   @default(true)
  viewerCount  Int       @default(0)
  peakViewers  Int       @default(0)
  isActive     Boolean   @default(false)
  isRecorded   Boolean   @default(false)
  recordingUrl String?
  giftTotal    Float     @default(0)
  tags         String    @default("[]")
  category     String?
  visibility   String    @default("PUBLIC")
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  coHosts      LiveStreamCoHost[]
  gifts        LiveStreamGift[]
  predictions  Prediction[]
  clips        Clip[]
  chatMessages LiveStreamChatMessage[] @relation("StreamChatMessages")

  @@index([hostId])
  @@index([isActive])
  @@index([createdAt])
}

model LiveStreamCoHost {
  id           String     @id @default(cuid())
  liveStreamId String
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  userId       String
  user         Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt     DateTime   @default(now())
  status       String     @default("PENDING")

  @@unique([liveStreamId, userId])
  @@index([liveStreamId])
}

model LiveStreamGift {
  id           String     @id @default(cuid())
  liveStreamId String
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  senderId     String
  giftType     String
  giftName     String
  amount       Float
  quantity     Int        @default(1)
  sentAt       DateTime   @default(now())

  @@index([liveStreamId])
  @@index([senderId])
}

model LiveStreamChatMessage {
  id           String     @id @default(cuid())
  liveStreamId String
  liveStream   LiveStream @relation("StreamChatMessages", fields: [liveStreamId], references: [id], onDelete: Cascade)
  userId       String
  user         Profile    @relation("UserChatMessages", fields: [userId], references: [id], onDelete: Cascade)
  message      String
  type         String     @default("COMMENT") // COMMENT | GIFT | SYSTEM
  giftAmount   Float?
  createdAt    DateTime   @default(now())

  @@index([liveStreamId])
  @@index([userId])
  @@index([createdAt])
}

model Prediction {
  id              String     @id @default(cuid())
  liveStreamId    String
  liveStream      LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  title           String
  status          String     @default("ACTIVE") // ACTIVE, LOCKED, RESOLVED, CANCELLED
  winningOptionId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  options PredictionOption[]
  bets    PredictionBet[]

  @@index([liveStreamId])
}

model PredictionOption {
  id           String          @id @default(cuid())
  predictionId String
  prediction   Prediction      @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  text         String
  totalPoints  Int             @default(0)
  bets         PredictionBet[]

  @@index([predictionId])
}

model PredictionBet {
  id           String           @id @default(cuid())
  predictionId String
  prediction   Prediction       @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  optionId     String
  option       PredictionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId       String
  user         Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  points       Int
  createdAt    DateTime         @default(now())

  @@unique([predictionId, userId])
  @@index([predictionId])
  @@index([userId])
}

model Clip {
  id           String      @id @default(cuid())
  title        String
  videoUrl     String
  thumbnailUrl String
  duration     Int
  viewsCount   Int         @default(0)
  creatorId    String
  creator      Profile     @relation("ClipCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  liveStreamId String?
  liveStream   LiveStream? @relation(fields: [liveStreamId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([creatorId])
  @@index([liveStreamId])
  @@index([createdAt])
}

// =============================================================================
// AudioRoom
// =============================================================================
model AudioRoom {
  id           String    @id @default(cuid())
  hostId       String
  host         Profile   @relation("AudioRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  isActive     Boolean   @default(false)
  isRecorded   Boolean   @default(false)
  recordingUrl String?
  maxSpeakers  Int       @default(10)
  tags         String    @default("[]")
  category     String?
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  speakers           AudioRoomSpeaker[]
  listeners          AudioRoomListener[]
  transcripts        AudioRoomTranscript[]
  transcriptSegments AudioRoomTranscriptSegment[]

  @@index([hostId])
  @@index([isActive])
  @@index([createdAt])
}

model AudioRoomSpeaker {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  userId      String
  user        Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  isMuted     Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@unique([audioRoomId, userId])
  @@index([audioRoomId])
}

model AudioRoomListener {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  userId      String
  user        Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  handRaised  Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@unique([audioRoomId, userId])
  @@index([audioRoomId])
}

// =============================================================================
// Product (Marketplace)
// =============================================================================
model Product {
  id           String   @id @default(cuid())
  sellerId     String
  seller       Profile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  price        Float
  images       String   @default("[]")
  category     String
  tags         String   @default("[]")
  inStock      Boolean  @default(true)
  stockCount   Int?
  sku          String?
  condition    String   @default("NEW")
  shippingInfo String?
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  salesCount   Int      @default(0)
  viewsCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders     Order[]
  reviews    ProductReview[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([sellerId])
  @@index([category])
  @@index([inStock])
  @@index([price])
  @@index([createdAt])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([productId, reviewerId])
  @@index([productId])
}

// =============================================================================
// Order
// =============================================================================
model Order {
  id              String      @id @default(cuid())
  buyerId         String
  buyer           Profile     @relation("OrderBuyer", fields: [buyerId], references: [id])
  productId       String?
  product         Product?    @relation(fields: [productId], references: [id])
  items           OrderItem[]
  quantity        Int         @default(1)
  unitPrice       Float
  total           Float
  status          String      @default("PENDING")
  shippingAddress String?
  trackingNumber  String?
  notes           String?
  stripePaymentId String?
  refundedAt      DateTime?
  refundReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([buyerId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Badge (Gamification)
// =============================================================================
model Badge {
  id          String   @id @default(cuid())
  userId      String
  user        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  name        String
  description String?
  iconUrl     String?
  tier        String   @default("BRONZE")
  awardedAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
}

// =============================================================================
// Streak (Gamification)
// =============================================================================
model Streak {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActivityAt  DateTime @default(now())
  totalDaysActive Int      @default(0)
  weeklyGoal      Int      @default(7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// =============================================================================
// Report (Moderation)
// =============================================================================
model Report {
  id          String    @id @default(cuid())
  reporterId  String
  reporter    Profile   @relation("ReportSource", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId    String
  targetType  String
  reason      String
  description String?
  status      String    @default("PENDING")
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  post        Post?      @relation("ReportedPost", fields: [postId], references: [id])
  postId      String?
  comment     Comment?   @relation("ReportedComment", fields: [commentId], references: [id])
  commentId   String?
  community   Community? @relation("ReportedCommunity", fields: [communityId], references: [id])
  communityId String?

  @@index([reporterId])
  @@index([targetId, targetType])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Hashtag
// =============================================================================
model Hashtag {
  id         String   @id @default(cuid())
  name       String   @unique
  postCount  Int      @default(0)
  isTrending Boolean  @default(false)
  trendScore Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  posts   PostHashtag[]
  savedBy UserSavedHashtag[]

  @@index([name])
  @@index([isTrending])
  @@index([trendScore])
}

model PostHashtag {
  id        String  @id @default(cuid())
  postId    String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([postId, hashtagId])
  @@index([hashtagId])
}

model UserSavedHashtag {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@unique([userId, hashtagId])
  @@index([userId])
}

// =============================================================================
// Subscription (Creator monetisation)
// =============================================================================
model Subscription {
  id                 String    @id @default(cuid())
  subscriberId       String
  subscriber         Profile   @relation("SubscriptionSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  creatorId          String
  creator            Profile   @relation("SubscriptionCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  tier               String    @default("BASIC")
  amount             Float
  currency           String    @default("USD")
  status             String    @default("ACTIVE")
  stripeSubId        String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([subscriberId, creatorId])
  @@index([subscriberId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Tip (Direct creator support)
// =============================================================================
model Tip {
  id              String   @id @default(cuid())
  senderId        String
  sender          Profile  @relation("TipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId      String
  receiver        Profile  @relation("TipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  amount          Float
  currency        String   @default("USD")
  message         String?
  stripePaymentId String?
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// =============================================================================
// Analytics (per-user daily aggregates)
// =============================================================================
model Analytics {
  id             String   @id @default(cuid())
  userId         String
  user           Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  impressions    Int      @default(0)
  reach          Int      @default(0)
  profileViews   Int      @default(0)
  followerGrowth Int      @default(0)
  postLikes      Int      @default(0)
  postComments   Int      @default(0)
  postShares     Int      @default(0)
  videoViews     Int      @default(0)
  liveViewers    Int      @default(0)
  revenueUsd     Float    @default(0)
  linkClicks     Int      @default(0)
  createdAt      DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// =============================================================================
// Bookmark (Post saves)
// =============================================================================
model Bookmark {
  id             String   @id @default(cuid())
  userId         String
  user           Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId         String
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  collectionName String?  @default("All Bookmarks")
  createdAt      DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

// =============================================================================
// Friends (social graph — distinct from follows)
// =============================================================================
model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  sender     Profile  @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Profile  @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  /// FriendRequestStatus: PENDING | ACCEPTED | DECLINED
  status     String   @default("PENDING")
  message    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Friendship {
  id        String        @id @default(cuid())
  // userAId < userBId enforced at app layer to keep pairs unique
  userAId   String
  userA     Profile       @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     Profile       @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  streak    FriendStreak?

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model CloseFriend {
  id        String   @id @default(cuid())
  ownerId   String
  owner     Profile  @relation("CloseFriendOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friendId  String
  friend    Profile  @relation("CloseFriendTarget", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ownerId, friendId])
  @@index([ownerId])
}

// =============================================================================
// Polls
// =============================================================================
model Poll {
  id            String    @id @default(cuid())
  postId        String    @unique
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  creatorId     String
  creator       Profile   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  question      String
  allowMultiple Boolean   @default(false)
  expiresAt     DateTime?
  isClosed      Boolean   @default(false)
  createdAt     DateTime  @default(now())

  options PollOption[]
  votes   PollVote[]

  @@index([creatorId])
}

model PollOption {
  id         String @id @default(cuid())
  pollId     String
  poll       Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text       String
  position   Int    @default(0)
  votesCount Int    @default(0)

  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([optionId, userId])
  @@index([pollId])
  @@index([userId])
}

// =============================================================================
// Photo Albums
// =============================================================================
model Album {
  id          String   @id @default(cuid())
  ownerId     String
  owner       Profile  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  coverUrl    String?
  /// AlbumVisibility: PUBLIC | FRIENDS | PRIVATE
  visibility  String   @default("PUBLIC")
  photoCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  photos Photo[]

  @@index([ownerId])
}

model Photo {
  id         String   @id @default(cuid())
  albumId    String
  album      Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  uploaderId String
  uploader   Profile  @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  width      Int?
  height     Int?
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([albumId])
  @@index([uploaderId])
}

// =============================================================================
// Events
// =============================================================================
model Event {
  id              String     @id @default(cuid())
  creatorId       String
  creator         Profile    @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  communityId     String?
  community       Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  coverImage      String?
  location        String?
  isOnline        Boolean    @default(false)
  onlineUrl       String?
  /// EventVisibility: PUBLIC | FRIENDS | PRIVATE
  visibility      String     @default("PUBLIC")
  category        String?
  startsAt        DateTime
  endsAt          DateTime?
  goingCount      Int        @default(0)
  interestedCount Int        @default(0)
  isCancelled     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  attendees EventAttendee[]

  @@index([creatorId])
  @@index([startsAt])
  @@index([visibility])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// RsvpStatus: GOING | INTERESTED | DECLINED | INVITED
  status    String   @default("INTERESTED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// =============================================================================
// Pages (business / creator pages)
// =============================================================================
model Page {
  id            String   @id @default(cuid())
  ownerId       String
  owner         Profile  @relation("PageOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  slug          String   @unique
  category      String   @default("GENERAL")
  description   String?
  avatarUrl     String?
  coverImage    String?
  website       String?
  isVerified    Boolean  @default(false)
  followerCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles     PageMember[]
  followers PageFollower[]

  @@index([ownerId])
  @@index([category])
}

model PageMember {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// PageRole: ADMIN | EDITOR | MODERATOR | ANALYST
  role      String   @default("EDITOR")
  createdAt DateTime @default(now())

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}

model PageFollower {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}

// =============================================================================
// Community join requests (private group approvals)
// =============================================================================
model CommunityJoinRequest {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JoinRequestStatus: PENDING | APPROVED | REJECTED
  status      String    @default("PENDING")
  message     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@index([status])
}

// =============================================================================
// Post tags (tagging people in posts/photos)
// =============================================================================
model PostTag {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation("PostTagUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// =============================================================================
// Life events (profile timeline milestones)
// =============================================================================
model LifeEvent {
  id          String   @id @default(cuid())
  userId      String
  user        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  category    String   @default("GENERAL")
  description String?
  icon        String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([occurredAt])
}

// =============================================================================
// SearchHistory
// =============================================================================
model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// =============================================================================
// Cart (E-Commerce)
// =============================================================================
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

// =============================================================================
// Ad (Advertiser Campaigns)
// =============================================================================
model Ad {
  id          String        @id @default(cuid())
  creatorId   String
  creator     Profile       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title       String
  copy        String
  imageUrl    String?
  targetUrl   String
  budget      Float
  spent       Float         @default(0)
  bidAmount   Float
  ageMin      Int?
  ageMax      Int?
  gender      String?
  location    String?
  isActive    Boolean       @default(true)
  impressions Int           @default(0)
  clicks      Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  placements  AdPlacement[]

  @@index([creatorId])
  @@index([isActive])
}

// =============================================================================
// Developer Webhooks
// =============================================================================
model WebhookSubscription {
  id           String               @id @default(cuid())
  userId       String
  user         Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  events       String
  secret       String
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deliveryLogs WebhookDeliveryLog[]

  @@index([userId])
  @@index([isActive])
}

model WebhookDeliveryLog {
  id             String              @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payload        String
  statusCode     Int?
  responseBody   String?
  durationMs     Int
  success        Boolean
  createdAt      DateTime            @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
}

// =============================================================================
// Fundraisers (Charity campaigns)
// =============================================================================
model Fundraiser {
  id           String               @id @default(cuid())
  creatorId    String
  creator      Profile              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  goalAmount   Float
  raisedAmount Float                @default(0)
  status       String               @default("ACTIVE") // ACTIVE | COMPLETED
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  donations    FundraiserDonation[]

  @@index([creatorId])
  @@index([status])
}

model FundraiserDonation {
  id           String     @id @default(cuid())
  fundraiserId String
  fundraiser   Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
  donorId      String
  donor        Profile    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  amount       Float
  createdAt    DateTime   @default(now())

  @@index([fundraiserId])
  @@index([donorId])
}

// =============================================================================
// Dating (Swipe & Crush simulator)
// =============================================================================
model DatingProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?
  prompts      String   @default("[]")
  lookingFor   String   @default("ANY")
  matches      String   @default("[]")
  crushes      String   @default("[]")
  datingEvents String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =============================================================================
// Ad Placements (Support DirectChat Status/Channel Ads)
// =============================================================================
model AdPlacement {
  id        String   @id @default(cuid())
  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  type      String
  page      String
  createdAt DateTime @default(now())

  @@index([adId])
}

// =============================================================================
// Bounties (Creator incentives)
// =============================================================================
model Bounty {
  id                String   @id @default(cuid())
  creatorId         String
  creator           Profile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  rewardAmount      Float
  status            String   @default("ACTIVE")
  participantsCount Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([creatorId])
}

// =============================================================================
// Server/Channel Architecture (Batch 7)
// =============================================================================

model Server {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  bannerUrl   String?
  ownerId     String
  owner       Profile  @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  inviteCode  String?  @unique
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          ServerMember[]
  roles            ServerRole[]
  channels         ServerChannel[]
  boosts           ServerBoost[]
  soundboardSounds SoundboardSound[]
  customEmojis     CustomEmoji[]
  messages         ServerMessage[]

  @@index([ownerId])
  @@index([isPublic])
}

model ServerMember {
  id            String                      @id @default(cuid())
  serverId      String
  server        Server                      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId        String
  user          Profile                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname      String?
  joinedAt      DateTime                    @default(now())
  roles         ServerMemberRole[]
  messages      ServerMessage[]
  stageSpeakers ServerChannelStageSpeaker[]

  @@unique([serverId, userId])
  @@index([serverId])
  @@index([userId])
}

model ServerRole {
  id          String             @id @default(cuid())
  name        String
  color       String             @default("#99aab5")
  hoist       Boolean            @default(false)
  position    Int                @default(0)
  permissions String             @default("[]") // JSON string array of permission names
  serverId    String
  server      Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members     ServerMemberRole[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([serverId])
}

model ServerMemberRole {
  memberId String
  member   ServerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  roleId   String
  role     ServerRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([memberId, roleId])
  @@index([memberId])
  @@index([roleId])
}

model ServerChannel {
  id                   String                      @id @default(cuid())
  name                 String
  type                 String                      @default("TEXT") // TEXT | VOICE | FORUM | STAGE | THREAD
  topic                String?
  position             Int                         @default(0)
  serverId             String
  server               Server                      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  parentId             String?
  parent               ServerChannel?              @relation("ChannelHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children             ServerChannel[]             @relation("ChannelHierarchy")
  messages             ServerMessage[]
  permissionOverwrites String                      @default("[]") // JSON string array of permission override rules
  stageSpeakers        ServerChannelStageSpeaker[]
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([serverId])
  @@index([parentId])
}

model ServerMessage {
  id          String          @id @default(cuid())
  serverId    String?
  server      Server?         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channelId   String
  channel     ServerChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId    String
  sender      Profile         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  memberId    String?
  member      ServerMember?   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  content     String?
  attachments String          @default("[]") // JSON array of file URL strings
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  replyToId   String?
  replyTo     ServerMessage?  @relation("ServerMessageReplies", fields: [replyToId], references: [id], onDelete: Cascade)
  replies     ServerMessage[] @relation("ServerMessageReplies")

  @@index([channelId])
  @@index([senderId])
  @@index([createdAt])
}

model ServerBoost {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([serverId])
  @@index([userId])
}

model SoundboardSound {
  id        String   @id @default(cuid())
  name      String
  soundUrl  String
  emoji     String?
  volume    Float    @default(1.0)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId    String?
  user      Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([serverId])
  @@index([userId])
}

model CustomEmoji {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId    String?
  user      Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([serverId])
  @@index([userId])
}

model ServerChannelStageSpeaker {
  id          String        @id @default(cuid())
  channelId   String
  channel     ServerChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  memberId    String
  member      ServerMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  isSpeaking  Boolean       @default(false)
  isRequested Boolean       @default(true)
  isApproved  Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@index([channelId])
  @@index([memberId])
}

// =============================================================================
// Professional & Jobs (Batch 8)
// =============================================================================

model Company {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  description  String?
  logoUrl      String?
  coverImage   String?
  website      String?
  industry     String?
  companySize  String? // e.g. "1-10", "11-50", "51-200", "201-500", "501-1000", "1000+"
  size         String? // Support E2E test field
  headquarters String?
  location     String? // Support E2E test field
  foundedAt    DateTime?
  ownerId      String
  owner        Profile   @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members   CompanyMember[]
  followers CompanyFollower[]
  jobs      Job[]

  @@index([ownerId])
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // ADMIN | MEMBER
  joinedAt  DateTime @default(now())

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model CompanyFollower {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model Job {
  id            String   @id @default(cuid())
  title         String
  description   String
  requirements  String? // Serialized JSON string array of skills or requirements
  location      String? // e.g. "San Francisco, CA"
  type          String   @default("FULL_TIME") // FULL_TIME | PART_TIME | CONTRACT | INTERNSHIP | TEMPORARY
  workplaceType String   @default("ON_SITE") // ON_SITE | HYBRID | REMOTE
  salaryRange   String? // e.g. "$120,000 - $150,000"
  salary        String? // Support E2E test field
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  posterId      String
  poster        Profile  @relation("JobPoster", fields: [posterId], references: [id], onDelete: Cascade)
  isActive      Boolean  @default(true)
  viewsCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  applications JobApplication[]

  @@index([companyId])
  @@index([posterId])
  @@index([isActive])
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   Profile  @relation("JobApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  resumeUrl   String?
  coverLetter String?
  status      String   @default("PENDING") // PENDING | REVIEWING | INTERVIEWING | OFFERED | REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
}

model InMailMessage {
  id         String   @id @default(cuid())
  senderId   String
  sender     Profile  @relation("InMailSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Profile  @relation("InMailReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  subject    String?
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Endorsement {
  id           String   @id @default(cuid())
  skill        String
  targetUserId String
  targetUser   Profile  @relation("EndorsementTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  endorserId   String
  endorser     Profile  @relation("EndorsementSender", fields: [endorserId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([targetUserId, endorserId, skill])
  @@index([targetUserId])
  @@index([endorserId])
}

model Recommendation {
  id           String   @id @default(cuid())
  requesterId  String?
  requester    Profile? @relation("RecommendationRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiverId   String
  receiver     Profile  @relation("RecommendationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  writerId     String
  writer       Profile  @relation("RecommendationWriter", fields: [writerId], references: [id], onDelete: Cascade)
  text         String
  relationship String? // e.g. "Managed writer directly"
  status       String   @default("PENDING") // REQUESTED | PENDING | APPROVED | REJECTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([requesterId])
  @@index([receiverId])
  @@index([writerId])
}

model LearningCourse {
  id              String   @id @default(cuid())
  title           String
  description     String
  instructor      String
  category        String?  @default("General") // e.g. "Software Engineering", "Business"
  duration        String? // e.g. "4 hours"
  durationMinutes Int      @default(0)
  level           String?  @default("BEGINNER")
  modulesList     String?  @default("[]")
  thumbnailUrl    String?
  videoUrl        String?
  isPremium       Boolean  @default(false)
  rating          Float    @default(0.0) // average out of 10
  ratingCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments LearningEnrollment[]

  @@index([category])
  @@index([rating])
}

model LearningEnrollment {
  id                 String         @id @default(cuid())
  courseId           String
  course             LearningCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId             String
  user               Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressPercentage Float          @default(0.0) // 0.0 to 100.0
  completedModules   String         @default("[]") // JSON array of completed module names/ids
  status             String         @default("ENROLLED") // ENROLLED | IN_PROGRESS | COMPLETED
  certificateUrl     String?
  completed          Boolean        @default(false)
  completedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model Article {
  id          String    @id @default(cuid())
  title       String
  content     String
  summary     String?
  coverImage  String?
  authorId    String
  author      Profile   @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  viewsCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([authorId])
  @@index([isPublished])
  @@index([createdAt])
}

// =============================================================================
// Forum-style Forum & Voting (Batch 9)
// =============================================================================

model Subforum {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  creatorId   String
  creator     Profile  @relation("SubforumCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  rules       String? // SQLite compatible
  memberCount Int      @default(0)
  postCount   Int      @default(0)
  customTheme String? // SQLite JSON string default "{}"
  isNSFW      Boolean  @default(false)
  isSpoiler   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members    SubforumMember[]
  posts      SubforumPost[]
  crossposts ForumCrosspost[]
  modActions ForumModAction[]

  @@index([creatorId])
  @@index([slug])
  @@index([createdAt])
}

model SubforumMember {
  id         String   @id @default(cuid())
  subforumId String
  subforum   Subforum @relation(fields: [subforumId], references: [id], onDelete: Cascade)
  userId     String
  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   @default("MEMBER") // MEMBER | MODERATOR | ADMIN
  flair      String?
  joinedAt   DateTime @default(now())
  isBanned   Boolean  @default(false)
  isMuted    Boolean  @default(false)

  @@unique([subforumId, userId])
  @@index([subforumId])
  @@index([userId])
  @@index([role])
}

model SubforumPost {
  id          String   @id @default(cuid())
  title       String
  content     String?
  type        String   @default("TEXT") // TEXT | POLL | LINK | MEDIA
  mediaUrls   String   @default("[]") // SQLite JSON string array
  pollOptions String? // SQLite JSON string
  pollVotes   String? // SQLite JSON string
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  score       Int      @default(0) // upvotes - downvotes
  authorId    String
  author      Profile  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subforumId  String
  subforum    Subforum @relation(fields: [subforumId], references: [id], onDelete: Cascade)
  isSpoiler   Boolean  @default(false)
  isNSFW      Boolean  @default(false)
  isLocked    Boolean  @default(false)
  isPinned    Boolean  @default(false)
  isAMA       Boolean  @default(false)
  karmaValue  Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments              SubforumComment[]
  crosspostsAsOriginal  ForumCrosspost[]  @relation("OriginalPost")
  crosspostsAsCrosspost ForumCrosspost[]  @relation("CrosspostedPost")
  modActions            ForumModAction[]

  @@index([authorId])
  @@index([subforumId])
  @@index([createdAt])
  @@index([score])
}

model SubforumComment {
  id          String            @id @default(cuid())
  content     String
  authorId    String
  author      Profile           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId      String
  post        SubforumPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      SubforumComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     SubforumComment[] @relation("CommentReplies")
  upvotes     Int               @default(0)
  downvotes   Int               @default(0)
  score       Int               @default(0)
  isDeleted   Boolean           @default(false)
  isAMAAnswer Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  modActions ForumModAction[]

  @@index([authorId])
  @@index([postId])
  @@index([parentId])
  @@index([createdAt])
}

model ForumVote {
  id         String   @id @default(cuid())
  userId     String
  user       Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId   String // Can represent SubforumPost.id or SubforumComment.id
  type       String // UPVOTE | DOWNVOTE
  targetType String // POST | COMMENT
  createdAt  DateTime @default(now())

  @@unique([userId, targetId, targetType])
  @@index([userId])
  @@index([targetId, targetType])
}

model ForumAward {
  id         String   @id @default(cuid())
  name       String
  icon       String
  price      Int      @default(0)
  senderId   String
  sender     Profile  @relation("AwardsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Profile  @relation("AwardsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  targetId   String // Post or Comment ID
  targetType String // POST | COMMENT
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([targetId, targetType])
}

model ForumCrosspost {
  id                String       @id @default(cuid())
  originalPostId    String
  originalPost      SubforumPost @relation("OriginalPost", fields: [originalPostId], references: [id], onDelete: Cascade)
  targetSubforumId  String
  targetSubforum    Subforum     @relation(fields: [targetSubforumId], references: [id], onDelete: Cascade)
  crosspostedPostId String
  crosspostedPost   SubforumPost @relation("CrosspostedPost", fields: [crosspostedPostId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())

  @@unique([originalPostId, targetSubforumId])
  @@index([originalPostId])
  @@index([targetSubforumId])
}

model ForumModAction {
  id              String           @id @default(cuid())
  subforumId      String
  subforum        Subforum         @relation(fields: [subforumId], references: [id], onDelete: Cascade)
  moderatorId     String
  moderator       Profile          @relation("ModActionModerator", fields: [moderatorId], references: [id], onDelete: Cascade)
  action          String // LOCK_POST, REMOVE_POST, REMOVE_COMMENT, BAN_USER, MUTE_USER
  targetUserId    String?
  targetUser      Profile?         @relation("ModActionTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetPostId    String?
  targetPost      SubforumPost?    @relation(fields: [targetPostId], references: [id], onDelete: SetNull)
  targetCommentId String?
  targetComment   SubforumComment? @relation(fields: [targetCommentId], references: [id], onDelete: SetNull)
  reason          String?
  createdAt       DateTime         @default(now())

  @@index([subforumId])
  @@index([moderatorId])
}

// =============================================================================
// Camera & AR (Batch 10)
// =============================================================================

model UserLocation {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude      Float
  longitude     Float
  shareLocation Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model DisappearingMedia {
  id         String    @id @default(cuid())
  senderId   String
  sender     Profile   @relation("DisappearingMediaSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Profile   @relation("DisappearingMediaReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  mediaUrl   String
  type       String    @default("IMAGE") // IMAGE | VIDEO
  isViewed   Boolean   @default(false)
  viewedAt   DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model FriendStreak {
  id                String     @id @default(cuid())
  friendshipId      String     @unique
  friendship        Friendship @relation(fields: [friendshipId], references: [id], onDelete: Cascade)
  count             Int        @default(0)
  lastInteractionAt DateTime   @default(now())
  expiresAt         DateTime
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([friendshipId])
}

model ARLens {
  id        String   @id @default(cuid())
  name      String
  iconUrl   String
  assetUrl  String
  category  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Geofilter {
  id         String   @id @default(cuid())
  name       String
  overlayUrl String
  minLat     Float
  maxLat     Float
  minLng     Float
  maxLng     Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model SavedMemory {
  id        String   @id @default(cuid())
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaUrl  String
  type      String
  caption   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// =============================================================================
// Batch 11 — Podcasts, Playlists, Transcripts
// =============================================================================

model Podcast {
  id          String           @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  authorId    String
  author      Profile          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category    String?
  episodes    PodcastEpisode[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([authorId])
}

model PodcastEpisode {
  id          String   @id @default(cuid())
  podcastId   String
  podcast     Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  title       String
  description String?
  audioUrl    String
  duration    Int      @default(0)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([podcastId])
}

model AudioPlaylist {
  id          String               @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  userId      String
  user        Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks      AudioPlaylistTrack[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId])
}

model AudioPlaylistTrack {
  id         String        @id @default(cuid())
  playlistId String
  playlist   AudioPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  title      String
  artist     String?
  audioUrl   String
  duration   Int           @default(0)
  position   Int           @default(0)
  createdAt  DateTime      @default(now())

  @@index([playlistId])
}

model AudioRoomTranscript {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  fullText    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([audioRoomId])
}

model AudioRoomTranscriptSegment {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  userId      String
  user        Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  text        String
  timestamp   DateTime  @default(now())

  @@index([audioRoomId])
  @@index([userId])
}
