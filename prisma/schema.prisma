// =============================================================================
// WakkaWakka — Prisma Schema
// Provider : SQLite (development) — swap datasource url for PostgreSQL in prod
// Generator: @prisma/client
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// NOTE: SQLite does not support native enums. We model them as String and
//       validate at the application layer. When migrating to PostgreSQL,
//       convert these to proper Prisma enum declarations.
// =============================================================================
// PostType        : TEXT | IMAGE | VIDEO | REEL | STORY | AUDIO | LIVE
// PostVisibility  : PUBLIC | FOLLOWERS | PRIVATE
// FollowStatus    : PENDING | ACCEPTED
// LikeType        : LIKE | LOVE | HAHA | WOW | SAD | ANGRY
// NotificationType: LIKE | COMMENT | FOLLOW | MENTION | REPLY | SHARE |
//                   LIVE_START | STORY_VIEW | COMMUNITY_INVITE | BADGE |
//                   SUBSCRIPTION | TIP | PURCHASE | SYSTEM
// TargetType      : POST | COMMENT | STORY | COMMUNITY | LIVE_STREAM | USER
// OrderStatus     : PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED | REFUNDED
// ReportReason    : SPAM | HARASSMENT | HATE_SPEECH | NUDITY | VIOLENCE |
//                   COPYRIGHT | MISINFORMATION | OTHER
// ReportStatus    : PENDING | REVIEWED | RESOLVED | DISMISSED
// SubscriptionStatus: ACTIVE | PAST_DUE | CANCELLED | TRIALING | INCOMPLETE
// VerificationTier: NONE | BLUE | GOLD | PLATINUM
// Theme           : SYSTEM | LIGHT | DARK

// =============================================================================
// User
// =============================================================================
model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  email              String    @unique
  displayName        String
  bio                String?
  avatar             String?
  coverImage         String?
  website            String?
  location           String?
  birthdate          DateTime?
  isVerified         Boolean   @default(false)
  /// VerificationTier: NONE | BLUE | GOLD | PLATINUM
  verificationTier   String    @default("NONE")
  isPremium          Boolean   @default(false)
  isPrivate          Boolean   @default(false)
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  /// Theme: SYSTEM | LIGHT | DARK
  theme              String    @default("SYSTEM")
  accentColor        String    @default("#3b82f6")
  language           String    @default("en")
  passwordHash       String?
  firebaseUid        String?   @unique
  isActive           Boolean   @default(true)
  isAdmin            Boolean   @default(false)
  isBanned           Boolean   @default(false)
  bannedAt           DateTime?
  bannedReason       String?
  lastSeenAt         DateTime?
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations — authored content
  posts              Post[]
  comments           Comment[]
  stories            Story[]
  communityPosts     CommunityPost[]

  // Relations — social graph
  followers          Follow[]         @relation("FollowTarget")
  following          Follow[]         @relation("FollowSource")
  blocksGiven        Block[]          @relation("BlockSource")
  blocksReceived     Block[]          @relation("BlockTarget")

  // Relations — messaging
  sentMessages       Message[]
  conversations      ConversationMember[]

  // Relations — reactions
  likes              Like[]

  // Relations — notifications
  notifications      Notification[]   @relation("NotificationRecipient")
  notificationActor  Notification[]   @relation("NotificationActor")

  // Relations — communities
  createdCommunities Community[]      @relation("CommunityCreator")
  communityMembers   CommunityMember[]

  // Relations — live & audio
  liveStreams        LiveStream[]     @relation("LiveStreamHost")
  coHostedStreams    LiveStreamCoHost[]
  audioRoomsHosted   AudioRoom[]      @relation("AudioRoomHost")
  audioRoomSpeakers  AudioRoomSpeaker[]
  audioRoomListeners AudioRoomListener[]

  // Relations — marketplace
  products           Product[]
  buyerOrders        Order[]          @relation("OrderBuyer")

  // Relations — gamification
  badges             Badge[]
  streak             Streak?

  // Relations — monetisation
  subscriptionsGiven Subscription[]   @relation("SubscriptionSubscriber")
  subscriptionsReceived Subscription[] @relation("SubscriptionCreator")
  tipsGiven          Tip[]            @relation("TipSender")
  tipsReceived       Tip[]            @relation("TipReceiver")

  // Relations — moderation
  reportsGiven       Report[]         @relation("ReportSource")

  // Relations — analytics
  analytics          Analytics[]

  // Relations — hashtags
  savedHashtags      UserSavedHashtag[]

  // Relations — post saves / bookmarks
  bookmarks          Bookmark[]

  // Relations — story views
  viewedStories      StoryView[]

  @@index([username])
  @@index([email])
  @@index([firebaseUid])
  @@index([createdAt])
}

// =============================================================================
// Post
// =============================================================================
model Post {
  id              String    @id @default(cuid())
  content         String?
  authorId        String
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  /// PostType: TEXT | IMAGE | VIDEO | REEL | STORY | AUDIO | LIVE
  type            String    @default("TEXT")
  /// PostVisibility: PUBLIC | FOLLOWERS | PRIVATE
  visibility      String    @default("PUBLIC")
  mediaUrls       String    @default("[]")  // JSON array stored as text
  hashtags        String    @default("[]")  // JSON array of hashtag strings
  collaboratorIds String    @default("[]")  // JSON array of user IDs
  productTag      String?   // product ID if this post tags a product
  isEphemeral     Boolean   @default(false)
  expiresAt       DateTime?
  likesCount      Int       @default(0)
  commentsCount   Int       @default(0)
  sharesCount     Int       @default(0)
  viewsCount      Int       @default(0)
  isPinned        Boolean   @default(false)
  isArchived      Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  editedAt        DateTime?
  // Reference to original post when sharing
  originalPostId  String?
  originalPost    Post?     @relation("PostShares", fields: [originalPostId], references: [id])
  shares          Post[]    @relation("PostShares")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  comments        Comment[]
  likes           Like[]
  reports         Report[]  @relation("ReportedPost")
  bookmarks       Bookmark[]
  postHashtags    PostHashtag[]

  @@index([authorId])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@index([isEphemeral, expiresAt])
  @@index([isDeleted])
}

// =============================================================================
// Comment
// =============================================================================
model Comment {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")
  content     String
  mediaUrl    String?
  likesCount  Int       @default(0)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  editedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  likes       Like[]
  reports     Report[]  @relation("ReportedComment")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
}

// =============================================================================
// Like
// =============================================================================
model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  /// LikeType: LIKE | LOVE | HAHA | WOW | SAD | ANGRY
  type      String   @default("LIKE")
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@index([userId])
}

// =============================================================================
// Follow
// =============================================================================
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)
  /// FollowStatus: PENDING | ACCEPTED
  status      String   @default("ACCEPTED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([status])
}

// =============================================================================
// Block
// =============================================================================
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlockSource", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// =============================================================================
// Conversation
// =============================================================================
model Conversation {
  id          String   @id @default(cuid())
  name        String?
  isGroup     Boolean  @default(false)
  avatarUrl   String?
  description String?
  createdById String?
  lastMessageAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     ConversationMember[]
  messages    Message[]

  @@index([createdAt])
  @@index([lastMessageAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin        Boolean      @default(false)
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?
  isMuted        Boolean      @default(false)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

// =============================================================================
// Message
// =============================================================================
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String?
  mediaUrl       String?
  /// MessageType: TEXT | IMAGE | VIDEO | AUDIO | FILE | STICKER | GIF | SYSTEM
  type           String       @default("TEXT")
  isRead         Boolean      @default(false)
  isDeleted      Boolean      @default(false)
  deletedAt      DateTime?
  editedAt       DateTime?
  replyToId      String?
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReplies")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Message reactions
  reactions      MessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isDeleted])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// =============================================================================
// Notification
// =============================================================================
model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  /// NotificationType: LIKE | COMMENT | FOLLOW | MENTION | REPLY | SHARE |
  ///                   LIVE_START | STORY_VIEW | COMMUNITY_INVITE | BADGE |
  ///                   SUBSCRIPTION | TIP | PURCHASE | SYSTEM
  type       String
  actorId    String?
  actor      User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  /// targetId references the entity the notification is about (postId, commentId, etc.)
  targetId   String?
  /// TargetType: POST | COMMENT | STORY | COMMUNITY | LIVE_STREAM | USER
  targetType String?
  message    String?
  imageUrl   String?
  actionUrl  String?
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([actorId])
}

// =============================================================================
// Story
// =============================================================================
model Story {
  id        String      @id @default(cuid())
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mediaUrl  String
  /// StoryType: IMAGE | VIDEO | TEXT | BOOMERANG
  type      String      @default("IMAGE")
  caption   String?
  linkUrl   String?
  musicUrl  String?
  filter    String?
  duration  Int?        // seconds for video stories
  expiresAt DateTime
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  // Relations
  views     StoryView[]

  @@index([authorId])
  @@index([expiresAt])
  @@index([isActive])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId  String
  viewer    User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([storyId, viewerId])
  @@index([storyId])
  @@index([viewerId])
}

// =============================================================================
// Community
// =============================================================================
model Community {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  avatarUrl   String?
  coverImage  String?
  creatorId   String
  creator     User     @relation("CommunityCreator", fields: [creatorId], references: [id])
  category    String   @default("GENERAL")
  /// CommunityVisibility: PUBLIC | PRIVATE | RESTRICTED
  visibility  String   @default("PUBLIC")
  rules       String?  // JSON array of rule objects
  tags        String   @default("[]") // JSON array of tag strings
  isVerified  Boolean  @default(false)
  memberCount Int      @default(0)
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     CommunityMember[]
  posts       CommunityPost[]
  reports     Report[]  @relation("ReportedCommunity")

  @@index([creatorId])
  @@index([category])
  @@index([visibility])
  @@index([createdAt])
}

model CommunityMember {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// CommunityRole: MEMBER | MODERATOR | ADMIN
  role        String    @default("MEMBER")
  joinedAt    DateTime  @default(now())
  isBanned    Boolean   @default(false)
  isMuted     Boolean   @default(false)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@index([role])
}

// =============================================================================
// CommunityPost
// =============================================================================
model CommunityPost {
  id            String    @id @default(cuid())
  communityId   String
  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content       String
  mediaUrls     String    @default("[]") // JSON array
  hashtags      String    @default("[]") // JSON array
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  isPinned      Boolean   @default(false)
  isApproved    Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  likes         CommunityPostLike[]
  comments      CommunityPostComment[]

  @@index([communityId])
  @@index([authorId])
  @@index([createdAt])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model CommunityPostComment {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  content   String
  parentId  String?
  parent    CommunityPostComment?  @relation("CommunityCommentReplies", fields: [parentId], references: [id])
  replies   CommunityPostComment[] @relation("CommunityCommentReplies")
  likesCount Int          @default(0)
  isDeleted Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

// =============================================================================
// LiveStream
// =============================================================================
model LiveStream {
  id           String   @id @default(cuid())
  hostId       String
  host         User     @relation("LiveStreamHost", fields: [hostId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  thumbnailUrl String?
  streamKey    String   @unique @default(cuid())
  playbackUrl  String?
  chatEnabled  Boolean  @default(true)
  viewerCount  Int      @default(0)
  peakViewers  Int      @default(0)
  isActive     Boolean  @default(false)
  isRecorded   Boolean  @default(false)
  recordingUrl String?
  giftTotal    Float    @default(0)
  tags         String   @default("[]") // JSON array
  category     String?
  /// LiveStreamVisibility: PUBLIC | FOLLOWERS | PRIVATE
  visibility   String   @default("PUBLIC")
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  coHosts      LiveStreamCoHost[]
  gifts        LiveStreamGift[]

  @@index([hostId])
  @@index([isActive])
  @@index([createdAt])
}

model LiveStreamCoHost {
  id           String     @id @default(cuid())
  liveStreamId String
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt     DateTime   @default(now())

  @@unique([liveStreamId, userId])
  @@index([liveStreamId])
}

model LiveStreamGift {
  id           String     @id @default(cuid())
  liveStreamId String
  liveStream   LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)
  senderId     String
  giftType     String
  giftName     String
  amount       Float
  quantity     Int        @default(1)
  sentAt       DateTime   @default(now())

  @@index([liveStreamId])
  @@index([senderId])
}

// =============================================================================
// AudioRoom
// =============================================================================
model AudioRoom {
  id          String   @id @default(cuid())
  hostId      String
  host        User     @relation("AudioRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isActive    Boolean  @default(false)
  isRecorded  Boolean  @default(false)
  recordingUrl String?
  maxSpeakers Int      @default(10)
  tags        String   @default("[]") // JSON array
  category    String?
  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  speakers    AudioRoomSpeaker[]
  listeners   AudioRoomListener[]

  @@index([hostId])
  @@index([isActive])
  @@index([createdAt])
}

model AudioRoomSpeaker {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isMuted     Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@unique([audioRoomId, userId])
  @@index([audioRoomId])
}

model AudioRoomListener {
  id          String    @id @default(cuid())
  audioRoomId String
  audioRoom   AudioRoom @relation(fields: [audioRoomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  @@unique([audioRoomId, userId])
  @@index([audioRoomId])
}

// =============================================================================
// Product (Marketplace)
// =============================================================================
model Product {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  images      String   @default("[]") // JSON array of image URLs
  category    String
  tags        String   @default("[]") // JSON array
  inStock     Boolean  @default(true)
  stockCount  Int?
  sku         String?
  condition   String   @default("NEW") // NEW | USED | REFURBISHED
  shippingInfo String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  salesCount  Int      @default(0)
  viewsCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orders      Order[]
  reviews     ProductReview[]

  @@index([sellerId])
  @@index([category])
  @@index([inStock])
  @@index([price])
  @@index([createdAt])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewerId String
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([productId, reviewerId])
  @@index([productId])
}

// =============================================================================
// Order
// =============================================================================
model Order {
  id              String   @id @default(cuid())
  buyerId         String
  buyer           User     @relation("OrderBuyer", fields: [buyerId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int      @default(1)
  unitPrice       Float
  total           Float
  /// OrderStatus: PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED | REFUNDED
  status          String   @default("PENDING")
  shippingAddress String?  // JSON object stored as text
  trackingNumber  String?
  notes           String?
  stripePaymentId String?
  refundedAt      DateTime?
  refundReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([buyerId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Badge (Gamification)
// =============================================================================
model Badge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// BadgeType: EARLY_ADOPTER | VERIFIED | CONTENT_CREATOR | POPULAR |
  ///            TOP_FAN | STREAMER | SELLER | COMMUNITY_LEADER | MILESTONE_*
  type        String
  name        String
  description String?
  iconUrl     String?
  tier        String   @default("BRONZE") // BRONZE | SILVER | GOLD | PLATINUM
  awardedAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
}

// =============================================================================
// Streak (Gamification)
// =============================================================================
model Streak {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActivityAt  DateTime @default(now())
  totalDaysActive Int      @default(0)
  weeklyGoal      Int      @default(7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// =============================================================================
// Report (Moderation)
// =============================================================================
model Report {
  id          String    @id @default(cuid())
  reporterId  String
  reporter    User      @relation("ReportSource", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId    String
  /// TargetType: POST | COMMENT | STORY | COMMUNITY | LIVE_STREAM | USER
  targetType  String
  /// ReportReason: SPAM | HARASSMENT | HATE_SPEECH | NUDITY | VIOLENCE |
  ///               COPYRIGHT | MISINFORMATION | OTHER
  reason      String
  description String?
  /// ReportStatus: PENDING | REVIEWED | RESOLVED | DISMISSED
  status      String    @default("PENDING")
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Optional FK links for convenience (only one will be set based on targetType)
  post        Post?     @relation("ReportedPost",      fields: [postId], references: [id])
  postId      String?
  comment     Comment?  @relation("ReportedComment",   fields: [commentId], references: [id])
  commentId   String?
  community   Community? @relation("ReportedCommunity", fields: [communityId], references: [id])
  communityId String?

  @@index([reporterId])
  @@index([targetId, targetType])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Hashtag
// =============================================================================
model Hashtag {
  id          String   @id @default(cuid())
  name        String   @unique // lowercase, no leading #
  postCount   Int      @default(0)
  isTrending  Boolean  @default(false)
  trendScore  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  posts       PostHashtag[]
  savedBy     UserSavedHashtag[]

  @@index([name])
  @@index([isTrending])
  @@index([trendScore])
}

model PostHashtag {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([postId, hashtagId])
  @@index([hashtagId])
}

model UserSavedHashtag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@unique([userId, hashtagId])
  @@index([userId])
}

// =============================================================================
// Subscription (Creator monetisation)
// =============================================================================
model Subscription {
  id            String   @id @default(cuid())
  subscriberId  String
  subscriber    User     @relation("SubscriptionSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  creatorId     String
  creator       User     @relation("SubscriptionCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  /// SubscriptionTier: BASIC | PRO | PREMIUM | CUSTOM
  tier          String   @default("BASIC")
  amount        Float
  currency      String   @default("USD")
  /// SubscriptionStatus: ACTIVE | PAST_DUE | CANCELLED | TRIALING | INCOMPLETE
  status        String   @default("ACTIVE")
  stripeSubId   String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([subscriberId, creatorId])
  @@index([subscriberId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// Tip (Direct creator support)
// =============================================================================
model Tip {
  id              String   @id @default(cuid())
  senderId        String
  sender          User     @relation("TipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId      String
  receiver        User     @relation("TipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  amount          Float
  currency        String   @default("USD")
  message         String?
  stripePaymentId String?
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// =============================================================================
// Analytics (per-user daily aggregates)
// =============================================================================
model Analytics {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime // Date only — use start-of-day UTC
  impressions     Int      @default(0)
  reach           Int      @default(0)
  profileViews    Int      @default(0)
  followerGrowth  Int      @default(0)
  postLikes       Int      @default(0)
  postComments    Int      @default(0)
  postShares      Int      @default(0)
  videoViews      Int      @default(0)
  liveViewers     Int      @default(0)
  revenueUsd      Float    @default(0)
  linkClicks      Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// =============================================================================
// Bookmark (Post saves)
// =============================================================================
model Bookmark {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  collectionName String? @default("All Bookmarks")
  createdAt   DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}
