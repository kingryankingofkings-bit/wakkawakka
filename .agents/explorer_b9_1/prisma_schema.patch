diff --git a/prisma/schema.prisma b/prisma/schema.prisma
index 1234567..89abcde 100644
--- a/prisma/schema.prisma
+++ b/prisma/schema.prisma
@@ -185,6 +185,17 @@ model User {
   writtenRecommendations   Recommendation[]        @relation("RecommendationWriter")
   learningEnrollments      LearningEnrollment[]
   articles                 Article[]               @relation("ArticleAuthor")
+
+  // Relations for Reddit-style Forum & Voting (Batch 9)
+  redditKarma              Int                     @default(0)
+  createdSubreddits        Subreddit[]             @relation("SubredditCreator")
+  subredditMemberships     SubredditMember[]
+  subredditPosts           SubredditPost[]
+  subredditComments        SubredditComment[]
+  redditVotes              RedditVote[]
+  sentAwards               RedditAward[]           @relation("AwardsSent")
+  receivedAwards           RedditAward[]           @relation("AwardsReceived")
+  modActions               RedditModAction[]       @relation("ModActionModerator")
+  targetModActions         RedditModAction[]       @relation("ModActionTargetUser")
 
   @@index([username])
   @@index([email])
@@ -1945,3 +1956,128 @@ model FundraiserDonation {
   createdAt      DateTime   @default(now())
   @@index([fundraiserId])
 }
+
+// =============================================================================
+// Reddit-style Forum & Voting (Batch 9)
+// =============================================================================
+
+model Subreddit {
+  id           String            @id @default(cuid())
+  name         String            @unique
+  slug         String            @unique
+  description  String?
+  creatorId    String
+  creator      User              @relation("SubredditCreator", fields: [creatorId], references: [id], onDelete: Cascade)
+  rules        String?           // SQLite compatible
+  memberCount  Int               @default(0)
+  postCount    Int               @default(0)
+  customTheme  String?           // SQLite JSON string default "{}"
+  isNSFW       Boolean           @default(false)
+  isSpoiler    Boolean           @default(false)
+  createdAt    DateTime          @default(now())
+  updatedAt    DateTime          @updatedAt
+
+  members      SubredditMember[]
+  posts        SubredditPost[]
+  crossposts   RedditCrosspost[]
+  modActions   RedditModAction[]
+
+  @@index([creatorId])
+  @@index([slug])
+  @@index([createdAt])
+}
+
+model SubredditMember {
+  id          String    @id @default(cuid())
+  subredditId String
+  subreddit   Subreddit @relation(fields: [subredditId], references: [id], onDelete: Cascade)
+  userId      String
+  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
+  role        String    @default("MEMBER") // MEMBER | MODERATOR | ADMIN
+  flair       String?
+  joinedAt    DateTime  @default(now())
+  isBanned    Boolean   @default(false)
+  isMuted     Boolean   @default(false)
+
+  @@unique([subredditId, userId])
+  @@index([subredditId])
+  @@index([userId])
+  @@index([role])
+}
+
+model SubredditPost {
+  id              String            @id @default(cuid())
+  title           String
+  content         String?
+  type            String            @default("TEXT") // TEXT | POLL | LINK | MEDIA
+  mediaUrls       String            @default("[]")   // SQLite JSON string array
+  pollOptions     String?           // SQLite JSON string
+  pollVotes       String?           // SQLite JSON string
+  upvotes         Int               @default(0)
+  downvotes       Int               @default(0)
+  score           Int               @default(0)      // upvotes - downvotes
+  authorId        String
+  author          User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
+  subredditId     String
+  subreddit       Subreddit         @relation(fields: [subredditId], references: [id], onDelete: Cascade)
+  isSpoiler       Boolean           @default(false)
+  isNSFW          Boolean           @default(false)
+  isLocked        Boolean           @default(false)
+  isPinned        Boolean           @default(false)
+  isAMA           Boolean           @default(false)
+  karmaValue      Int               @default(1)
+  createdAt       DateTime          @default(now())
+  updatedAt       DateTime          @updatedAt
+
+  comments        SubredditComment[]
+  crosspostsAsOriginal RedditCrosspost[] @relation("OriginalPost")
+  crosspostsAsCrosspost RedditCrosspost[] @relation("CrosspostedPost")
+  modActions      RedditModAction[]
+
+  @@index([authorId])
+  @@index([subredditId])
+  @@index([createdAt])
+  @@index([score])
+}
+
+model SubredditComment {
+  id          String             @id @default(cuid())
+  content     String
+  authorId    String
+  author      User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
+  postId      String
+  post        SubredditPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
+  parentId    String?
+  parent      SubredditComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
+  replies     SubredditComment[] @relation("CommentReplies")
+  upvotes     Int                @default(0)
+  downvotes   Int                @default(0)
+  score       Int                @default(0)
+  isDeleted   Boolean            @default(false)
+  isAMAAnswer Boolean            @default(false)
+  createdAt   DateTime           @default(now())
+  updatedAt   DateTime           @updatedAt
+
+  modActions  RedditModAction[]
+
+  @@index([authorId])
+  @@index([postId])
+  @@index([parentId])
+  @@index([createdAt])
+}
+
+model RedditVote {
+  id          String   @id @default(cuid())
+  userId      String
+  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
+  targetId    String   // Can represent SubredditPost.id or SubredditComment.id
+  type        String   // UPVOTE | DOWNVOTE
+  targetType  String   // POST | COMMENT
+  createdAt   DateTime @default(now())
+
+  @@unique([userId, targetId, targetType])
+  @@index([userId])
+  @@index([targetId, targetType])
+}
+
+model RedditAward {
+  id          String   @id @default(cuid())
+  name        String
+  icon        String
+  price       Int      @default(0)
+  senderId    String
+  sender      User     @relation("AwardsSent", fields: [senderId], references: [id], onDelete: Cascade)
+  receiverId  String
+  receiver    User     @relation("AwardsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
+  targetId    String   // Post or Comment ID
+  targetType  String   // POST | COMMENT
+  createdAt   DateTime @default(now())
+
+  @@index([senderId])
+  @@index([receiverId])
+  @@index([targetId, targetType])
+}
+
+model RedditCrosspost {
+  id                 String        @id @default(cuid())
+  originalPostId     String
+  originalPost       SubredditPost @relation("OriginalPost", fields: [originalPostId], references: [id], onDelete: Cascade)
+  targetSubredditId  String
+  targetSubreddit    Subreddit     @relation(fields: [targetSubredditId], references: [id], onDelete: Cascade)
+  crosspostedPostId  String
+  crosspostedPost    SubredditPost @relation("CrosspostedPost", fields: [crosspostedPostId], references: [id], onDelete: Cascade)
+  createdAt          DateTime      @default(now())
+
+  @@unique([originalPostId, targetSubredditId])
+  @@index([originalPostId])
+  @@index([targetSubredditId])
+}
+
+model RedditModAction {
+  id              String            @id @default(cuid())
+  subredditId     String
+  subreddit       Subreddit         @relation(fields: [subredditId], references: [id], onDelete: Cascade)
+  moderatorId     String
+  moderator       User              @relation("ModActionModerator", fields: [moderatorId], references: [id], onDelete: Cascade)
+  action          String            // LOCK_POST, REMOVE_POST, REMOVE_COMMENT, BAN_USER, MUTE_USER
+  targetUserId    String?
+  targetUser      User?             @relation("ModActionTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
+  targetPostId    String?
+  targetPost      SubredditPost?    @relation(fields: [targetPostId], references: [id], onDelete: SetNull)
+  targetCommentId String?
+  targetComment   SubredditComment? @relation(fields: [targetCommentId], references: [id], onDelete: SetNull)
+  reason          String?
+  createdAt       DateTime          @default(now())
+
+  @@index([subredditId])
+  @@index([moderatorId])
+}
